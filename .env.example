# Postgres connection string (free Supabase project — Transaction pooler URI).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
JWT_SECRET=replace-this-in-production
ADMIN_DEFAULT_PASSWORD=Admin@123

# SMTP for OTP + booking emails (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=IMA Guesthouse <no-reply@imatnsb-hqgh.com>
BOOKING_ALERT_TO=secretary@imatnsb-hqgh.com

# WhatsApp Cloud API — alerts to all 6 admins
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_ADMIN_NUMBERS=
WHATSAPP_ADMIN_NUMBER=
WHATSAPP_GUEST_TEMPLATE_NAME=booking_confirmation

# Return OTP in API response for testing only
OTP_DEBUG=false
