# Postgres connection string. A free Supabase project works out of the box:
# Supabase Dashboard -> Project Settings -> Database -> Connection string (URI).
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
JWT_SECRET=replace-this-in-production

# Default password used when seeding the 6 admin accounts (admin1..admin6).
ADMIN_DEFAULT_PASSWORD=Admin@123
VITE_API_BASE_URL=
VITE_IMA_UPI_ID=secretary@imatnsb-hqgh.com
VITE_IMA_UPI_NAME=IMA Guesthouse

# SMTP for OTP + booking emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=IMA Guesthouse <no-reply@imatnsb-hqgh.com>
BOOKING_ALERT_TO=secretary@imatnsb-hqgh.com

# WhatsApp Cloud API variables
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# All 6 admins get a booking alert. Comma-separate the numbers in E.164 digits
# (country code + number, no +). Example: 9198xxxxxxx,9199xxxxxxx,...
WHATSAPP_ADMIN_NUMBERS=
# Legacy single-admin fallback (still supported if WHATSAPP_ADMIN_NUMBERS is empty)
WHATSAPP_ADMIN_NUMBER=
WHATSAPP_GUEST_TEMPLATE_NAME=booking_confirmation

# Optional: return OTP in API response for testing only
OTP_DEBUG=false
