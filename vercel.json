{
  "framework": null,
  "buildCommand": "echo 'static site - no build step'",
  "installCommand": "npm install",
  "outputDirectory": "project",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/router?route=:path*" },
    { "source": "/((?!api/|images/|.*\\.).*)", "destination": "/index.html" }
  ]
}
